{
  "name": "cursor-chat-prompt-library",
  "displayName": "Cursor Chat Prompt Library",
  "description": "750 prompt templates for Cursor AI chat. Primary: Ctrl+Alt+T (Cmd+Alt+T on macOS); also Ctrl+Alt+Shift+P. 36 categories (Python × 50, others × 20). QuickPick → insert into chat.",
  "version": "0.8.1",
  "publisher": "rufat",
  "license": "MIT",
  "readme": "readme.md",
  "changelog": "CHANGELOG.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/rufatpro/plugins.git"
  },
  "homepage": "https://github.com/rufatpro/plugins",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "icon": "images/icon.png",
  "keywords": [
    "cursor",
    "chat",
    "AI",
    "composer",
    "agent",
    "prompt",
    "prompt library",
    "templates",
    "python",
    "javascript",
    "html",
    "typescript",
    "react",
    "sql",
    "git",
    "django",
    "nextjs",
    "fastapi",
    "docker",
    "testing",
    "tailwind",
    "vue",
    "php",
    "laravel",
    "c",
    "cpp",
    "c++",
    "go",
    "rust",
    "dotnet",
    "spring",
    "kubernetes",
    "graphql",
    "mongodb",
    "flutter",
    "wordpress",
    "pandas",
    "security",
    "devops",
    "beginner",
    "programming languages",
    "machine learning",
    "ml",
    "sklearn",
    "pytorch"
  ],
  "activationEvents": [
    "onCommand:cursorChatPromptLibrary.pick",
    "onCommand:cursorChatPromptLibrary.insert",
    "onCommand:cursorChatPromptLibrary.insertWebsite",
    "onCommand:cursorChatPromptLibrary.insertPython",
    "onCommand:cursorChatPromptLibrary.insertJavaScript"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorChatPromptLibrary.pick",
        "title": "Pick Prompt (Category, then Template)",
        "category": "Cursor Chat Prompt Library"
      },
      {
        "command": "cursorChatPromptLibrary.insert",
        "title": "Insert Prompt into Chat (All Categories)",
        "category": "Cursor Chat Prompt Library"
      },
      {
        "command": "cursorChatPromptLibrary.insertWebsite",
        "title": "Insert Website Prompt",
        "category": "Cursor Chat Prompt Library"
      },
      {
        "command": "cursorChatPromptLibrary.insertPython",
        "title": "Insert Python Prompt",
        "category": "Cursor Chat Prompt Library"
      },
      {
        "command": "cursorChatPromptLibrary.insertJavaScript",
        "title": "Insert JavaScript Prompt",
        "category": "Cursor Chat Prompt Library"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+alt+shift+p",
        "mac": "cmd+alt+shift+p",
        "command": "-editor.action.codeAction",
        "when": "editorTextFocus",
        "args": { "kind": "refactor.introduce.parameter" }
      },
      {
        "key": "ctrl+alt+shift+p",
        "mac": "cmd+alt+shift+p",
        "command": "-editor.action.codeAction",
        "when": "editorTextFocus"
      },
      {
        "command": "cursorChatPromptLibrary.pick",
        "key": "ctrl+alt+shift+p",
        "mac": "cmd+alt+shift+p",
        "when": "editorTextFocus && !terminalFocus && !inQuickOpen"
      },
      {
        "command": "cursorChatPromptLibrary.pick",
        "key": "ctrl+alt+shift+p",
        "mac": "cmd+alt+shift+p",
        "when": "!editorTextFocus && !terminalFocus && !inQuickOpen"
      },
      {
        "command": "cursorChatPromptLibrary.pick",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "editorTextFocus && !terminalFocus && !inQuickOpen"
      },
      {
        "command": "cursorChatPromptLibrary.pick",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "!editorTextFocus && !terminalFocus && !inQuickOpen"
      }
    ]
  },
  "scripts": {
    "package": "vsce package",
    "lint": "echo \"No lint configured\""
  },
  "vsce": {
    "baseContentUrl": "https://github.com/rufatpro/plugins/tree/main/vscode/cursor-chat-prompt-library"
  }
}
