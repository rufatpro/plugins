{
  "name": "cursor-chat-prompt-library-ru",
  "displayName": "Cursor Chat Prompt Library RU",
  "description": "710 русскоязычных шаблонов Prompt для AI-чата в Cursor. 34 категории (Python × 50, остальные × 20). C, C++, PHP, Laravel, Go, Rust и др. QuickPick → вставка в Chat.",
  "version": "0.5.5",
  "publisher": "rufat",
  "license": "MIT",
  "readme": "readme.md",
  "changelog": "CHANGELOG.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/rufatpro/ide-plugins.git"
  },
  "homepage": "https://github.com/rufatpro/ide-plugins",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "images/icon.png",
  "keywords": [
    "cursor",
    "chat",
    "AI",
    "composer",
    "agent",
    "prompt",
    "prompt library",
    "templates",
    "python",
    "javascript",
    "html",
    "typescript",
    "react",
    "sql",
    "git",
    "django",
    "nextjs",
    "fastapi",
    "docker",
    "testing",
    "tailwind",
    "vue",
    "php",
    "laravel",
    "c",
    "cpp",
    "c++",
    "go",
    "rust",
    "dotnet",
    "spring",
    "kubernetes",
    "graphql",
    "mongodb",
    "flutter",
    "wordpress",
    "pandas",
    "security",
    "devops",
    "beginner"
  ],
  "activationEvents": [
    "onCommand:cursorChatPromptLibraryRu.pick",
    "onCommand:cursorChatPromptLibraryRu.insert",
    "onCommand:cursorChatPromptLibraryRu.insertWebsite",
    "onCommand:cursorChatPromptLibraryRu.insertPython",
    "onCommand:cursorChatPromptLibraryRu.insertJavaScript"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorChatPromptLibraryRu.pick",
        "title": "Выбрать промпт (категория -> шаблон)",
        "category": "Cursor Chat Prompt Library RU"
      },
      {
        "command": "cursorChatPromptLibraryRu.insert",
        "title": "Вставить промпт в чат (все категории)",
        "category": "Cursor Chat Prompt Library RU"
      },
      {
        "command": "cursorChatPromptLibraryRu.insertWebsite",
        "title": "Вставить промпт Website",
        "category": "Cursor Chat Prompt Library RU"
      },
      {
        "command": "cursorChatPromptLibraryRu.insertPython",
        "title": "Вставить промпт Python",
        "category": "Cursor Chat Prompt Library RU"
      },
      {
        "command": "cursorChatPromptLibraryRu.insertJavaScript",
        "title": "Вставить промпт JavaScript",
        "category": "Cursor Chat Prompt Library RU"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+alt+shift+p",
        "mac": "cmd+alt+shift+p",
        "command": "-editor.action.codeAction",
        "when": "editorTextFocus",
        "args": { "kind": "refactor.introduce.parameter" }
      },
      {
        "key": "ctrl+alt+shift+p",
        "mac": "cmd+alt+shift+p",
        "command": "-editor.action.codeAction",
        "when": "editorTextFocus"
      },
      {
        "command": "cursorChatPromptLibraryRu.pick",
        "key": "ctrl+alt+shift+p",
        "mac": "cmd+alt+shift+p",
        "when": "editorTextFocus && !terminalFocus && !inQuickOpen"
      },
      {
        "command": "cursorChatPromptLibraryRu.pick",
        "key": "ctrl+alt+shift+p",
        "mac": "cmd+alt+shift+p",
        "when": "!editorTextFocus && !terminalFocus && !inQuickOpen"
      }
    ]
  },
  "scripts": {
    "package": "vsce package",
    "lint": "echo \"No lint configured\""
  },
  "vsce": {
    "baseContentUrl": "https://github.com/rufatpro/ide-plugins/tree/main/vscode/cursor-chat-prompt-library-ru"
  }
}
